{
  "name": "aep-agent-orchestrator",
  "version": "1.0.0",
  "description": "Adobe Experience Platform Agent Orchestrator - Coordinates Audience, Content, Journey, and Analytics Agents",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "seed": "node scripts/seed.js",
    "docker:build": "docker build -t aep-orchestrator:latest .",
    "docker:run": "docker run -p 5000:5000 --env-file .env aep-orchestrator:latest",
    "kafka:start": "docker-compose -f docker-compose.yml up",
    "mongo:seed": "mongosh < scripts/mongodb-init.js"
  },
  "keywords": [
    "adobe",
    "experience-platform",
    "aep",
    "orchestration",
    "marketing-automation",
    "personalization",
    "journey-management",
    "audience-segmentation"
  ],
  "author": "Kedar - EY Adobe Practice",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.0.3",
    "redis": "^4.6.12",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "optionalDependencies": {
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  }
}
