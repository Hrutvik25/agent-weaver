# ==================== SERVER CONFIGURATION ====================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ==================== DATABASE ====================
# Local MongoDB for development
MONGO_URI=mongodb://localhost:27017/aep-orchestrator

# Production MongoDB (Comment out local URI above and use this)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/aep-orchestrator?retryWrites=true&w=majority

# ==================== REDIS CACHE ====================
REDIS_URL=redis://localhost:6379

# Production Redis (e.g., AWS ElastiCache)
# REDIS_URL=redis://:password@endpoint:6379

# ==================== KAFKA MESSAGE BROKER ====================
KAFKA_BROKERS=localhost:9092
# Multiple brokers: broker1:9092,broker2:9092,broker3:9092

# ==================== ADOBE EXPERIENCE PLATFORM ====================
# Get these credentials from your Adobe Developer Console
# https://developer.adobe.com/

ADOBE_API_KEY=your_adobe_api_key_here
ADOBE_ORG_ID=your_adobe_org_id@AdobeOrg
ADOBE_TECH_ACCOUNT=your_adobe_technical_account_id@techacct.adobe.com
ADOBE_PRIVATE_KEY=/path/to/your/private.key
# Or inline: -----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Adobe IMS Endpoints
ADOBE_IMS_BASE_URL=https://ims-na1.adobelogin.com
ADOBE_AEP_BASE_URL=https://platform.adobe.io

# Adobe Real-time Customer Data Platform
ADOBE_RTCDP_DATASET_ID=your_dataset_id
ADOBE_RTCDP_SCHEMA_ID=your_schema_id

# ==================== CLAUDE AI INTEGRATION ====================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Model configuration
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=2048

# ==================== SERVICE INTEGRATIONS ====================
# Optional: ServiceNow Integration (for AI Agent Fabric)
SERVICENOW_INSTANCE=https://your-instance.service-now.com
SERVICENOW_API_KEY=your_servicenow_api_key

# Optional: Confluent Kafka Cloud
CONFLUENT_API_KEY=your_confluent_key
CONFLUENT_API_SECRET=your_confluent_secret

# ==================== SECURITY ====================
# JWT Secret for API authentication (optional)
JWT_SECRET=your_jwt_secret_key_change_in_production

# CORS Settings
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== MONITORING & LOGGING ====================
# Sentry (optional error tracking)
SENTRY_DSN=https://your_sentry_key@sentry.io/project-id

# ==================== DATA PIPELINE ====================
# Kafka Topics
KAFKA_TOPIC_AUDIENCE_DATA=audience-raw-data
KAFKA_TOPIC_ANALYTICS_EVENTS=aep-analytics-events
KAFKA_TOPIC_FEEDBACK=aep-feedback
KAFKA_TOPIC_JOURNEYS=aep-journeys

# ==================== DEVELOPMENT FEATURES ====================
# Enable/disable features during development
ENABLE_MOCK_ADOBE_API=false
ENABLE_KAFKA_LOGGING=true
ENABLE_DETAILED_ERRORS=true

# ==================== DEPLOYMENT ====================
# For Docker/Kubernetes deployments
DEPLOYMENT_ENV=local
REPLICA_COUNT=1

# Health check configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000
